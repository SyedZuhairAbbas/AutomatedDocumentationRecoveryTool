<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.MainController"
            style="-fx-background-color: #1e1e2e;">

    <!-- TOP HEADER -->
    <top>
        <VBox style="-fx-background-color: #181825; -fx-padding: 20;">
            <Label text="⚡ DocGen"
                   style="-fx-text-fill: #cba6f7; -fx-font-size: 28px; -fx-font-weight: bold;"/>
            <Label text="Automated Documentation Recovery Tool"
                   style="-fx-text-fill: #a6adc8; -fx-font-size: 13px;"/>
        </VBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <VBox spacing="15" style="-fx-padding: 25;">

            <!-- FILE SELECTION ROW -->
            <HBox spacing="15" style="-fx-alignment: center-left;">
                <Button text="📂 Select Python File"
                        onAction="#handleFileSelect"
                        style="-fx-background-color: #89b4fa; -fx-text-fill: #1e1e2e;
                               -fx-font-weight: bold; -fx-font-size: 13px;
                               -fx-padding: 10 20; -fx-background-radius: 8;"/>
                <Label fx:id="fileNameLabel"
                       text="No file selected"
                       style="-fx-text-fill: #a6adc8; -fx-font-size: 13px;"/>
            </HBox>

            <!-- ANALYZE BUTTON -->
            <Button fx:id="analyzeBtn"
                    text="🔍 Analyze File"
                    onAction="#handleAnalyze"
                    disable="true"
                    style="-fx-background-color: #a6e3a1; -fx-text-fill: #1e1e2e;
                           -fx-font-weight: bold; -fx-font-size: 13px;
                           -fx-padding: 10 20; -fx-background-radius: 8;"/>

            <!-- SUMMARY BAR -->
            <HBox fx:id="summaryBox"
                  spacing="20"
                  visible="false"
                  style="-fx-background-color: #181825;
             -fx-padding: 12 15;
             -fx-background-radius: 8;
             -fx-alignment: center-left;">
                <Label fx:id="totalFunctionsLabel"
                       text="⚙️ Functions: 0"
                       style="-fx-text-fill: #a6e3a1; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <Label fx:id="totalClassesLabel"
                       text="🏛 Classes: 0"
                       style="-fx-text-fill: #89b4fa; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <Label fx:id="totalParamsLabel"
                       text="📥 Parameters: 0"
                       style="-fx-text-fill: #f9e2af; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <Label fx:id="analysisStatusLabel"
                       text="✅ Analysis Complete"
                       style="-fx-text-fill: #cba6f7; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            </HBox>

            <!-- OUTPUT AREA -->
            <Label text="Generated Documentation:"
                   style="-fx-text-fill: #cdd6f4; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            <TextArea fx:id="outputArea"
                      editable="false"
                      wrapText="true"
                      prefHeight="380"
                      style="-fx-control-inner-background: #181825;
                             -fx-text-fill: #cdd6f4;
                             -fx-font-family: 'Consolas';
                             -fx-font-size: 13px;
                             -fx-background-radius: 8;"/>

            <!-- EXPORT BUTTON -->
            <Button fx:id="exportBtn"
                    text="💾 Export as Markdown"
                    onAction="#handleExport"
                    disable="true"
                    style="-fx-background-color: #f38ba8; -fx-text-fill: #1e1e2e;
                           -fx-font-weight: bold; -fx-font-size: 13px;
                           -fx-padding: 10 20; -fx-background-radius: 8;"/>
        </VBox>
    </center>

</BorderPane>